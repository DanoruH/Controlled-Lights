$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
    Anchor: (Width: 800, Height: 600);

  #Title {
    Group {
      $C.@Title {
        @Text = "LIGHTING SYSTEM";
      }
    }
  }

  #Content {
    LayoutMode: Left;
    Padding: (Full: 20);
    Anchor: (Height: 530);

    Group #NetworkPanel{
      LayoutMode: Top;
      Anchor: (Width: 520);
      Background: #19252F;
      Padding: (Full: 15);

      Label {
        Text: "Network Administration";
        Style: (
          FontSize: 18,
          RenderBold: true,
          TextColor: #bfcdd5,
          RenderUppercase: true
        );
        Anchor: (Height: 30);
      }

      //ActionButton
      Group #AditionButton {
        LayoutMode: Left;
        Padding: (Bottom: 10);

        $C.@TextButton #NetworkAdd{
          Text: "Add";
          Anchor: (Width: 115, Height: 35);
        }
      }

      //LISTA
      Group #NetworkList {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Height: 320);
        Background: #2a3a47(0.9);
        Padding: (Full: 10);
      }

      //MORE BUTTONS

      Group #ActionButtons{
        LayoutMode: Left;
        Padding: (Top: 10);

        $C.@TextButton #NetworkRemove {
          Text: "Remove";
          Anchor: (Width: 115, Height: 35, Right: 10);
        }

        $C.@TextButton #NetworkRemoveAll {
          Text: "Remove All";
          Anchor: (Width: 125, Height: 35);
          Padding: (Full: 10);
        }
      }
    }

    Group #Information{
      LayoutMode: Top;
      Anchor: (Width: 240);
      Background: #0e1720(0.9);
      Padding: (Full: 20);

      Label {
        Text: "Lights :";

        Style: (
          FontSize: 18,
          RenderBold: true,
          TextColor: #bfcdd5,
          RenderUppercase: true
        );
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 80);
        Padding: (Full: 10);

        Group {
          Anchor: (Height: 55, Width: 55);
          Background: (TexturePath: "../Icons/Build-Lights.png");
        }

        Group {
          LayoutMode: CenterMiddle;

          Label #Total {
            Text: " TOTAL: 0";
            Style: (
              FontSize: 18,
              RenderBold: true,
              TextColor: #bfcdd5,
              RenderUppercase: true
            );
            Padding: (Left: 25);
          }
        }
      }

      Label {
        Text: "Switch:";

        Style: (
          FontSize: 18,
          RenderBold: true,
          TextColor: #bfcdd5,
          RenderUppercase: true
        );
      }

      Group {
        LayoutMode: Center;
        Anchor: (Height: 70);
        Padding: (Full: 5);

        ItemIcon #Icon{
          Anchor: (Width: 64, Height: 64);
        }
      }
    }
  }
}
